# =====================================================================
# CLASS CENTER — PRODUCTION ENVIRONMENT VARIABLES (Vercel + Supabase)
# =====================================================================
# Copy this file to .env.production (or set these directly in Vercel
# Project Settings → Environment Variables → Production).
#
# DO NOT commit the real .env.production file to GitHub.
# This .example file is safe to commit.
# =====================================================================

# ---------- DATABASE (Supabase PostgreSQL) ----------
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string

# Transaction pooler (port 6543) — used by the app at runtime (Prisma Client)
DATABASE_URL="postgresql://postgres.[PROJECT]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Session pooler / direct connection (port 5432) — used by Prisma Migrate / db push
DIRECT_URL="postgresql://postgres.[PROJECT]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---------- AUTH SECURITY ----------
# IMPORTANT: Generate a long random string (>= 32 chars) for production.
# Generate with: openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"

# ---------- EMAIL (Gmail SMTP) ----------
# Used by src/lib/email.ts to send admin notifications.
# Create an App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER="supportclasscenter@gmail.com"
EMAIL_PASS="REPLACE_WITH_GMAIL_APP_PASSWORD"

# ---------- NEXTAUTH (optional, only if you activate NextAuth.js) ----------
# NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
# NEXTAUTH_URL="https://your-domain.vercel.app"

# ---------- NODE ENV ----------
NODE_ENV="production"

# ---------- PAYMENT LINKS (already in src/lib/constants.ts but can be overridden) ----------
# These are currently hardcoded in constants.ts. If you want to override per-environment,
# uncomment and set them here:
# WAVE_PAY_LINK="https://pay.wave.com/m/M_xM5azSzKhAsr/c/ci/"
# DJAMO_PAY_LINK="https://pay.djamo.com/8mu1o"

# ---------- WHATSAPP (already in src/lib/constants.ts) ----------
# WHATSAPP_NUMBER="+225 07 08 72 59 39"
# WHATSAPP_LINK="https://wa.me/2250708725939"

# =====================================================================
# VERCEL DEPLOYMENT CHECKLIST
# =====================================================================
# 1. Push your code to GitHub (include prisma/supabase-migration.sql + this file)
# 2. Create Supabase project: https://supabase.com/dashboard
# 3. Run prisma/supabase-migration.sql in Supabase SQL Editor
# 4. In Vercel: New Project → import GitHub repo → Framework: Next.js
# 5. In Vercel Project Settings → Environment Variables → add ALL the above
# 6. Set Build Command:   bun run vercel-build
#    Set Install Command: bun install
# 7. Deploy. First deploy will run prisma generate + next build.
# 8. Verify: visit https://your-domain.vercel.app, login as admin, test flows.
# =====================================================================
